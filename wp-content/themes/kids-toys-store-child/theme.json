					"slug": "custom-dark-green-header"
				}
			]
		}
	},
	"styles": {
		"blocks": {
			"core/group": {
				"spacing": {
					"blockGap": "0",
					"padding": {
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)",
						"top": "var(--wp--preset--spacing--30)"
					}
				}
			},
			"core/paragraph": {
				"spacing": {
					"margin": {
						"bottom": "0",
						"top": "0"
					},
					"padding": {
						"bottom": "0",
						"top": "0"
					}
				}
			},
			"woocommerce/product-specifications": {
				"css": "border-color: white;\n"
			}
		},
		"elements": {
			"h3": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--medium)"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			}
		},
		"typography": {
			"fontSize": "var(--wp--preset--font-size--small)",
			"fontStyle": "normal",
			"fontWeight": "500",
			"lineHeight": "1.5"
		}
	}
}